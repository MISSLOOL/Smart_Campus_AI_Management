<view class="chat-container">
  <!-- 顶部栏 -->
  <view class="custom-nav">
    <view class="nav-left" bindtap="goBack">
      <text>←</text>
    </view>
    <text class="nav-title">聊天室</text>
    <view class="nav-right">
      <text class="online-count">在线 {{onlineCount}} 人</text>
    </view>
  </view>

  <!-- 消息列表 -->
  <scroll-view class="message-list" scroll-y scroll-into-view="{{scrollToView}}" scroll-with-animation enhanced show-scrollbar="{{false}}">
    <!-- 欢迎消息 -->
    <view class="welcome-section" wx:if="{{messages.length === 0}}">
      <view class="welcome-icon">💬</view>
      <text class="welcome-text">欢迎来到聊天室</text>
      <text class="welcome-hint">开始和大家聊天吧~</text>
    </view>
    
    <block wx:for="{{messages}}" wx:key="index">
      <!-- 时间分割线 -->
      <view class="time-divider" wx:if="{{item.showTime}}">
        <text class="time-divider-text">{{item.timeDivider}}</text>
      </view>
      
      <!-- 系统消息 -->
      <view class="system-message" wx:if="{{item.type === 'system'}}">
        <view class="system-bubble">
          <text class="system-text">{{item.content}}</text>
        </view>
      </view>
      
      <!-- 普通消息 -->
      <view class="message-item {{item.isSelf ? 'self' : 'other'}}" wx:else id="msg-{{index}}">
        <view class="avatar-wrapper">
          <image class="avatar" src="{{item.avatar || '/images/xxx.jpg'}}" mode="aspectFill"/>
          <view class="avatar-online-dot" wx:if="{{!item.isSelf}}"></view>
        </view>
        <view class="message-content">
          <text class="sender-name" wx:if="{{!item.isSelf}}">{{item.sender}}</text>
          <view class="bubble-wrapper">
            <view class="bubble">
              <text class="bubble-text">{{item.content}}</text>
            </view>
            <view class="bubble-tail {{item.isSelf ? 'self-tail' : 'other-tail'}}"></view>
          </view>
          <text class="time">{{item.timeStr}}</text>
        </view>
      </view>
    </block>
    <view class="message-placeholder" id="msg-bottom"></view>
  </scroll-view>

  <!-- 输入区域 -->
  <view class="input-bar">
    <view class="input-wrapper">
      <input class="input" 
             value="{{inputText}}" 
             bindinput="onInput" 
             placeholder="说点什么..." 
             placeholder-class="input-placeholder"
             confirm-type="send" 
             bindconfirm="sendMessage" 
             adjust-position="{{true}}" 
             focus="{{inputFocus}}" 
             bindfocus="onInputFocus" 
             bindblur="onInputBlur"
             cursor-spacing="20"/>
    </view>
    <view class="send-btn {{inputText ? 'active' : ''}}" bindtap="sendMessage">
      <text class="send-text">发送</text>
    </view>
  </view>
</view>
