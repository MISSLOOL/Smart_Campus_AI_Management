<!-- 自定义导航栏 -->
<view class="sidebar {{isSidebarOpen ? 'open' : ''}}">
  <view class="sidebar-content">
    <view class="search-container">
      <view class="search-input">
        <text class="search-icon">🔍</text>
        <input 
          class="input-field"
          type="text" 
          placeholder="搜索对话内容、标题..." 
          value="{{searchValue}}" 
          bindinput="onSearch" 
          confirm-type="search"
        />
        <text class="clear-icon" wx:if="{{searchValue}}" bindtap="clearSearch">✕</text>
      </view>
    </view>

    <view class="sidebar-item" bindtap="createNewChat">新建对话</view>

    <!-- ✅ 历史记录（可滚动 + 固定高度） -->
    <view class="history-section">
      <view class="history-title">历史记录</view>
      <scroll-view class="history-list" scroll-y>
        <view 
          class="history-item" 
          wx:for="{{historyList}}" 
          wx:key="id"
          bindtap="loadChatHistory"
          data-id="{{item.id}}"
        >
          {{item.title || '无标题对话'}}
        </view>
        <view 
          class="history-item delete-all" 
          wx:if="{{historyList.length > 0}}"
          bindtap="clearAllHistory"
        >
          清空所有历史
        </view>
      </scroll-view>
    </view>

    <view class="sidebar-item">设置</view>
    <view class="sidebar-item" bindtap="goHome">返回</view>
  </view>
</view>

<!-- 遮罩层 -->
<view class="overlay {{isSidebarOpen ? 'show' : ''}}" bindtap="closeSidebar"></view>

<view class="custom-nav">
  <view class="nav-left" bindtap="toggleSidebar">
    <view class="menu-icon">
      <view class="menu-bar"></view>
      <view class="menu-bar"></view>
      <view class="menu-bar"></view>
    </view>
  </view>
  <view class="nav-title">AI对话</view>
</view>

<view class="ai-page">
  <scroll-view class="chat-scroll" scroll-y scroll-into-view="last" scroll-with-animation>
    <view class="message-box">
      <block wx:for="{{messages}}" wx:key="index">
        <view selectable="true" class="message {{item.role === 'user' ? 'user' : 'ai'}}">
          <view class="bubble" bindtap="previewImage" data-index="{{index}}">
            <view wx:if="{{item.images && item.images.length > 0}}" class="message-img-container">
              <image src="{{item.images[0]}}" class="message-img" mode="aspectFill"></image>
              <view wx:if="{{item.role === 'user' && item.images.length > 1}}" class="message-img-mask">
                <text class="message-img-count">{{item.images.length}}+</text>
              </view>
            </view>
            <text selectable="true">{{item.content}}</text>
            <view 
              wx:if="{{item.role === 'assistant' && item.content}}" 
              class="copy-btn" 
              catchtap="copyText" 
              data-content="{{item.content}}"
            >复制</view>
          </view>
        </view>
      </block>
      <view id="last"></view>
    </view>
  </scroll-view>

  <view class="stack-preview" wx:if="{{previewImgs.length > 0}}">
    <block wx:for="{{previewImgs}}" wx:key="*this">
      <view class="stack-preview-item">
        <image src="{{item}}" class="mini-preview-img" mode="aspectFill"></image>
        <view class="mini-close" bindtap="deleteImage" data-index="{{index}}">×</view>
      </view>
    </block>
  </view>

  <view class="stack-model" catchtap="showModelPicker" hover-class="model-btn-active">
    {{modelList[modelIndex].label}}
  </view>

  <view class="bottom-area">
    <view class="left-grid">
      <view class="stack-plus" wx:if="{{isSupportImage}}">
        <view class="icon-btn" bindtap="chooseImage">
          <view class="plus"></view>
        </view>
      </view>
    </view>

    <view class="right-input">
      <input
        class="input"
        placeholder="输入你的问题..."
        value="{{inputText}}"
        bindinput="onInput"
        confirm-type="send"
        bindconfirm="sendMessage"
      />
      <view
        class="send-btn {{(!inputText && previewImgs.length === 0) || loading ? 'disabled' : ''}}"
        bindtap="sendMessage"
      >发送</view>
    </view>
  </view>
</view>